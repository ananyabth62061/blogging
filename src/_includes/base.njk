<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>Play & Win Real Money | DD Game App</title>

    <!-- Primary Meta Tags -->
    <meta name="title" content="Play & Win Real Money | DD Game App">
    <meta name="description" content="Download DD Game App from ddgamesapps.co.in and win real cash by playing Ludo, Rummy, Poker & more. Get a ₹100 welcome bonus. Join now!">
    <meta name="keywords" content="DD Game, real money games, ludo app, rummy app, poker app, win cash games, gaming app India">
    <meta name="author" content="DD Game Team">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://ddgamesapps.co.in/">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://ddgamesapps.co.in/">
    <meta property="og:title" content="Play & Win Real Money | DD Game App">
    <meta property="og:description" content="Play Ludo, Poker & more. Win cash instantly. Trusted by thousands of players in India. Get ₹100 bonus on sign-up!">
    <meta property="og:image" content="https://ddgamesapps.co.in/src/assets/blog/dd-game-logo.png">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="https://ddgamesapps.co.in/">
    <meta name="twitter:title" content="Play & Win Real Money | DD Game App">
    <meta name="twitter:description" content="Win real cash by playing your favorite games on DD Game. Instant withdrawals. Safe & secure.">
    <meta name="twitter:image" content="https://ddgamesapps.co.in/src/assets/blog/dd-game-logo.png">

    <!-- Favicon -->
    <link rel="icon" href="/src/assets/blog/dd-game-logo.png" type="image/png">

    <!-- Styles & Scripts -->
    <link rel="stylesheet" href="/style.css">
    <script defer src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    {% include 'header.njk' %}
    <main>
      {{ content | safe }}
    </main>
    {% include 'footer.njk' %}

    <!-- Netlify Identity Script Fix -->
    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", (user) => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
  </body>
</html>
